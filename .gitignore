# Secrets
.env
.mcp.json

# User data (created per-install)
context/memory/*
!context/memory/.gitkeep
context/.lets-go-onboarded
projects/
research_context/*.md

# Ingested research artifacts (created by /lets-go first-run)
/research_artifacts/

# Installer state
.claude/skills/_catalog/installed.json

# Local settings
.claude/settings.local.json
.claude/hooks_info/ccnotify.db
.claude/hooks_info/ccnotify.log*

# Scientific environment
.venv/
repro/ledger.jsonl

# MCP servers build artifacts
mcp-servers/*/node_modules/
mcp-servers/*/dist/

# Tool catalog (generated by sci-tools setup)
data/tooluniverse-catalog.json

# Python cache
__pycache__/
*.pyc

# System
.DS_Store
.backup/

# Cron logs
cron/logs/

# GSD planning state — internal development history, not source.
# Contains phase plans, debug notes, roadmap artifacts that change
# per-developer. Keeping this gitignored means each install has its
# own local planning state without leaking dev history to consumers.
/.planning/

# GSD agent worktrees — transient scratch dirs used by parallel
# agent runs. Not source; never tracked.
/.claude/worktrees/

# Scheduler runtime lock (written by the cron dispatcher)
.claude/scheduled_tasks.lock

# Test run outputs (tests regenerate these on each run)
tests/e2e_output/

# Generated artifacts from scripts/export-md.py — regenerated on
# demand from the source .md; DOCX/PDF are derived outputs, not
# source. Keep the .md in git; exclude the renders.
# Figures live under docs/figures/ and ARE committed — GitHub's
# in-repo Mermaid renderer is unreliable, so we ship the PNGs so
# the whitepaper renders correctly in the GitHub preview.
docs/**/*.docx
docs/**/*.pdf

# User-supplied PDFs dropped into docs/ (keep the framework docs in
# git but let users park personal reading material in docs/ without
# it showing up as dirty).
docs/*.pdf

# Whitelist the canonical whitepaper PDF — served by the Pages site
# at /organon/organon-whitepaper.pdf so the "Whitepaper" link opens
# in-browser without redirecting users off-site.
!docs/organon-whitepaper.pdf

# Throwaway scratch files
/test-arg.md

# Local-only skills (kept on disk, excluded from public repo)
.claude/skills/tool-substack/

# Local review/notes files
updates-susbtack-post.md
updates-susbtack-post-2.md

# Local-only social-publisher skill (kept on disk, excluded from public repo)
.claude/skills/tool-social-publisher/
