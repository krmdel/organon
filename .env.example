# API keys for Organon skills
# This file is auto-copied to .env by the installer — just fill in your keys below
# All keys are optional — skills work without them and tell you when one would help

# Firecrawl — web scraping, content extraction (https://www.firecrawl.dev/app)
# Used by: tool-firecrawl-scraper, sci-communication, /lets-go link scan
# Free tier: 500 credits/month. Fallback: WebFetch.
FIRECRAWL_API_KEY=

# Google Gemini — image generation via Gemini 3 Pro Image (https://ai.google.dev/)
# Used by: viz-nano-banana (images, infographics, scientific illustrations)
# Free tier available. No fallback — required for image generation.
GEMINI_API_KEY=

# OpenAI — Reddit trend search with real engagement metrics (https://platform.openai.com/api-keys)
# Used by: sci-trending-research
# Fallback: WebSearch (no metrics).
OPENAI_API_KEY=

# xAI — X/Twitter trend search with real engagement (https://console.x.ai/)
# Used by: sci-trending-research
# Fallback: WebSearch (no metrics).
XAI_API_KEY=

# YouTube Data API v3 — channel listing, @handle resolution (https://console.cloud.google.com/apis/credentials)
# Used by: tool-youtube (channel mode)
# Fallback: transcript mode still works via yt-dlp without this key.
YOUTUBE_API_KEY=

# NCBI (PubMed) — academic paper search via E-utilities (https://www.ncbi.nlm.nih.gov/account/)
# Used by: paper-search MCP server (sci-literature-research)
# Free: 10 req/sec with key, 3/sec without. Optional.
NCBI_API_KEY=

# OpenAlex — open scholarly metadata (https://openalex.org/users/me)
# Used by: paper-search MCP server (sci-literature-research)
# Free API key required since Feb 2026.
OPENALEX_API_KEY=

# Semantic Scholar — academic paper search with citation graph
# (https://www.semanticscholar.org/product/api)
# Used by: paper-search MCP server (sci-literature-research)
# Free: dedicated 1 RPS with key vs shared pool without. Optional.
S2_API_KEY=

# Substack — draft publishing via private API (session cookie auth, no OAuth)
# Used by: tool-substack (markdown → Substack draft + image upload)
# Extraction guide: .claude/skills/tool-substack/references/credentials-guide.md
# All three are required. Use a SANDBOX publication for first runs.
# SUBSTACK_PUBLICATION_URL: Your Substack publication URL (https://yourname.substack.com)
SUBSTACK_PUBLICATION_URL=
# SUBSTACK_SESSION_TOKEN: Extract from browser DevTools → Application → Cookies → substack.sid (https://substack.com)
SUBSTACK_SESSION_TOKEN=
# SUBSTACK_USER_ID: Extract from browser DevTools → Application → Cookies → substack.uid (https://substack.com)
SUBSTACK_USER_ID=

# Unpaywall — open-access full-text resolver for citation verification
# Docs: https://unpaywall.org/products/api
# Used by: sci-writing (Tier-D full-text claim verification), cron/jobs/sci-writing-bib-audit.md
# Required to fetch open-access PDFs for "does the paper actually say what we claim" checks.
# Any valid email works — Unpaywall uses it for rate-limit identification only (no signup required).
# Leave empty to fall back to abstract-only verification (MAJOR instead of CRITICAL on missing body).
UNPAYWALL_EMAIL=

# Obsidian vault path — absolute path to your local Obsidian vault (not an API key)
# Download Obsidian: https://obsidian.md/
# Used by: tool-obsidian (knowledge-base sync gate)
# Leave empty to disable Obsidian integration entirely.
OBSIDIAN_VAULT=
